
# ======================================================
# 🧠 Golem Brain (Web Gemini 大腦設定)
# ======================================================
# Google Gemini API Keys (必填)
# 說明：用於 DOM Doctor 自癒功能與與某些對話分析。
# 取得：https://aistudio.google.com/app/apikey
# 技巧：支援多組 Key 輪替 (KeyChain)，請用半形逗號 "," 分隔。
# ⚠️ 首次啟動後請前往 http://localhost:3000/dashboard 進行設定。

GEMINI_API_KEYS=

# ======================================================
# ⚙️ System Config (系統進階設定)
# ======================================================
# 瀏覽器資料暫存路徑
# 說明：存放 Puppeteer 的 Login Session，重啟後不用重新登入 Google。
# 預設：./golem_memory

USER_DATA_DIR=./golem_memory

# 測試模式 (通常設為 false)
# true: 只測試程式碼是否能執行，不啟動瀏覽器。
# false: 正常啟動。

GOLEM_TEST_MODE=false

# 部署模式 (SINGLE | MULTI)
# SINGLE: (預設) 單機模式，使用單一組 Telegram 設定。
# MULTI:  多機模式，使用 golems.json 進行多實例配置（從 Dashboard 建立）。

GOLEM_MODE=SINGLE

# WSL2 無 GUI，必須開 headless
# PUPPETEER_HEADLESS=new

# Web Dashboard
DASHBOARD_PORT=3000
ENABLE_WEB_DASHBOARD=true

# ======================================================
# 🧠 Memory Engine (記憶引擎設定)
# ======================================================
# 選擇模式：
# browser - (預設) 使用內建 memory.html，無須安裝額外軟體。
# qmd     - (進階) 使用 qmd 混合搜尋，需安裝 Bun 與 qmd。
# (進階選用) 指定 qmd 執行檔路徑，若已加入系統 PATH 則留空即可
# GOLEM_QMD_PATH=/path/to/your/qmd

GOLEM_MEMORY_MODE=browser

# ======================================================
# ☁️ OTA Update Config (空中升級設定)
# ======================================================
# 指定 /update 指令抓取原始碼的 GitHub 儲存庫
# 預設若留空則使用：https://raw.githubusercontent.com/Arvincreator/project-golem/main/

GITHUB_REPO=

# ======================================================
# 🦞 Moltbook Social Network (AI 社交網絡)
# ======================================================
# Moltbook API Key (核心憑證)
# 取得方式：啟動 Golem 後，對他說「去註冊 Moltbook」。

MOLTBOOK_API_KEY=

MOLTBOOK_AGENT_NAME=

PUPPETEER_REMOTE_DEBUGGING_PORT=9222

# ======================================================
# External Service URLs (Optional)
# ======================================================
# Leave blank to run standalone without external services
# GOLEM_AGENT_ID=yeren
# RAG_URL=
# WARROOM_URL=
# WARROOM_AUTH_TOKEN=
# WORKER_HEALTH_URL=
# WORKER_INTEL_URL=
# WORKER_ORCHESTRATOR_URL=
# WORKER_CONTENT_URL=
# WORKER_REVENUE_URL=
# WORKER_RAG_URL=
# WORKER_ANALYTICS_URL=
# WORKER_AUTO_AGENT_URL=
# SANDBOX_EXTRA_DOMAINS=

# ======================================================
# Grounding Verification (v9.3)
# ======================================================
# off  - Zero overhead (default)
# quick - Heuristic confidence badge only
# full  - RAG-backed claim verification + attribution
GROUNDING_MODE=off

# ======================================================
# v9.4 TITAN — Advanced Agent Features
# ======================================================
# MCTS escalation: full Monte Carlo Tree Search when backtracking fails
ENABLE_MCTS_ESCALATION=false
# Adaptive planning: plan-execute-observe-replan loop
ENABLE_ADAPTIVE_PLANNING=true
# Voyager-style auto skill synthesis from repeated patterns
ENABLE_SKILL_SYNTHESIS=true
# Letta/MemGPT agent-editable memory blocks
ENABLE_AGENT_MEMORY=true
# MetaGPT SOP multi-agent workflows
ENABLE_SOP_AGENTS=false
# Rate limiting: max brain calls per minute
MAX_BRAIN_CALLS_PER_MINUTE=20
# Budget: max brain calls per single adaptive plan
MAX_BRAIN_CALLS_PER_PLAN=5

# v9.5 TITAN-FIX — Feature flags
# Use adaptive plan result instead of redundant brain call (A2 guard)
ENABLE_ADAPTIVE_RESULT_GUARD=true

# ======================================================
# v10.0+ Brain Engine & Integrations
# ======================================================
# Brain Engine: router | monica-web | monica | sdk | ollama | puppeteer
GOLEM_BRAIN_ENGINE=router

# L0/L1 auto-approved commands (SecurityManager whitelist)
# COMMAND_WHITELIST=ls,pwd,date,whoami,cat,grep,find,head,tail,df,free,node,npm,echo,git,curl,wc,sort,uniq,mkdir,touch,cp,which,env,hostname,python3

# Monica.im API
# MONICA_API_KEY=
# MONICA_DEFAULT_MODEL=gpt-4o
# MONICA_WEB_DEFAULT_MODEL=gpt-4o

# Ollama (local fallback)
# OLLAMA_URL=http://localhost:11434/v1
# OLLAMA_MODEL=deepseek-r1:8b

# Anthropic Claude API (v10.5)
# ANTHROPIC_API_KEY=

# YEDAN Fleet Integration
# FLEET_AUTH_TOKEN=
# CF_API_TOKEN=

# v10.9 SubAgent System (default: disabled)
ENABLE_SUBAGENTS=false
