<?xml version="1.0" encoding="UTF-8"?>
<golem-config version="2.1" updated="2026-03-17">

  <node id="rensin" role="primary">
    <platform>wsl2</platform>
    <mode>puppeteer</mode>
    <telegram enabled="true" token-env="TG_TOKEN"/>
    <dashboard port="4000"/>
  </node>

  <rag>
    <remote url="https://yedan-graph-rag.yagami8095.workers.dev"
            auth-env="FLEET_AUTH_TOKEN"
            timeout-ms="15000"/>
    <local driver="magma" data-file="src/memory/graph/nodes.json"/>
    <sync interval-minutes="60"/>
  </rag>

  <gemini>
    <sdk package="@google/genai" version="1.44.0"/>
    <model primary="gemini-2.5-flash" fallback="gemini-3-flash-preview"/>
    <keys rotation="round-robin">
      <key env="GEMINI_API_KEY_1"/>
      <key env="GEMINI_API_KEY_2"/>
      <key env="GEMINI_API_KEY_3"/>
      <key env="GEMINI_API_KEY_4"/>
    </keys>
    <limits rpm="60" daily="1500"/>
  </gemini>

  <!-- v10.0: Brain engine configuration -->
  <brains engine="router">
    <router total-timeout-ms="90000">
      <fallback-chain>monica-web,monica,sdk,ollama</fallback-chain>
      <sticky-routing enabled="true" window-size="20"/>
    </router>
    <monica>
      <api base-url-env="MONICA_API_URL" key-env="MONICA_API_KEY"
           default-model="gpt-4o" timeout-ms="60000"/>
      <web default-model="gpt-4o" daily-limit="500"/>
    </monica>
    <ollama url="http://localhost:11434/v1" model="deepseek-r1:8b"
            timeout-ms="90000" fallback-models="qwen2:1.5b">
      <gpu num-gpu="auto" timeout-ms="30000"
           adaptive-ctx="true" min-ctx="8192"/>
    </ollama>
  </brains>

  <!-- v10.0: Security rules externalized -->
  <security>
    <command-whitelist>ls,pwd,date,whoami,cat,grep,find,head,tail,df,free,node,npm,echo,git,curl</command-whitelist>
    <level-rules>
      <rule level="L0" pattern="^(ls|pwd|date|whoami|echo|hostname)(\s|$)"/>
      <rule level="L1" pattern="^(cat|grep|find|head|tail|df|free|node|npm|git)\s"/>
      <rule level="L2" pattern="^(curl|wget|python3?|pip)\s"/>
      <rule level="L3" pattern="(rm\s+-rf|mkfs|dd\s|shutdown|reboot|kill\s+-9|>\s*/dev/)"/>
    </level-rules>
  </security>

  <!-- v10.0: Memory engine configuration -->
  <memory mode="browser">
    <chat-log>
      <retention hourly-hours="72" daily-days="30" monthly-months="12" yearly-years="5"/>
      <compression timeout-ms="60000" max-words-daily="500" max-words-monthly="300"/>
    </chat-log>
    <three-layer working-cap="50" episodic-cap="500" summary-threshold="0.5"/>
    <context-engineer token-budget="32768" reserve-pct="15" overflow-cleanup-hours="24"/>
  </memory>

  <!-- v10.0: Logging configuration -->
  <logging>
    <system buffer-size="100" flush-interval-ms="500"
            rotate-max-mb="10" rotate-keep="3"/>
    <console timestamp="true" level="info"/>
  </logging>

  <!-- v10.0: Retry strategy -->
  <retry max-attempts="3" base-delay-ms="1000" max-delay-ms="30000"
         jitter="decorrelated" retryable-codes="429,500,502,503,504"/>

  <telegram engine="grammy">
    <polling timeout-sec="30"
             max-consecutive-errors="10"
             backoff-max-sec="60"
             jitter="true"/>
    <startup>
      <delete-webhook drop-pending="false"/>
      <wait-sec>3</wait-sec>
    </startup>
    <health>
      <check-interval-sec>300</check-interval-sec>
      <alert-threshold polling-success-rate-min="95"
                       response-latency-max-ms="5000"
                       uptime-min-sec="300"/>
    </health>
  </telegram>

  <circuit-breakers>
    <breaker name="fleet" timeout-ms="5000" reset-ms="30000" error-pct="50"/>
    <breaker name="rag" timeout-ms="3000" reset-ms="20000" error-pct="40"/>
    <breaker name="gemini" timeout-ms="30000" reset-ms="60000" error-pct="50"/>
    <breaker name="telegram" timeout-ms="10000" reset-ms="15000" error-pct="30"/>
    <breaker name="monica" timeout-ms="60000" reset-ms="60000" error-pct="50"/>
    <breaker name="ollama" timeout-ms="90000" reset-ms="30000" error-pct="50"/>
  </circuit-breakers>

  <failover>
    <heartbeat interval-sec="30" storage="d1"/>
    <timeout detect-sec="90" confirm-sec="180"/>
    <takeover notify="telegram" auto="true"/>
  </failover>

  <!-- v10.5: Vector store configuration -->
  <vector-store db-path="golem_memory/vectors.db" max-vectors="10000">
    <embeddings provider="gemini" model="text-embedding-004"
                fallback="ollama:nomic-embed-text"
                cache-size="100" batch-size="20"/>
  </vector-store>

  <!-- v10.5: Claude brain configuration -->
  <claude api-key-env="ANTHROPIC_API_KEY"
          default-model="claude-opus-4-6-20250515"
          timeout-ms="120000" max-tokens="8192"/>

  <!-- v10.5: Claude Gateway -->
  <claude-gateway enabled="true" token-env="CLAUDE_GATEWAY_TOKEN" rate-limit-rpm="60"/>

  <!-- v12.0: Error Pattern Learner configuration -->
  <error-pattern-learner max-patterns="200" dedup-threshold="0.8"
                          retention-days="90" auto-suggest="true"/>

  <!-- v12.0: Scan Quality Tracker configuration -->
  <scan-quality-tracker max-records="500" worthless-threshold="3"
                         auto-skip="true" min-effectiveness="0.1"/>

  <!-- v12.0: Worker Health Auditor configuration -->
  <worker-health-auditor timeout-ms="5000" max-consecutive-failures="3"
                          check-interval-min="30" max-history="200"/>

  <!-- v12.0: Security Auditor configuration -->
  <security-auditor ai-risk-checks="true" traditional-weight="0.6"
                     ai-risk-weight="0.4" max-risk-score="100"/>

  <!-- v12.0: RAG Quality Monitor configuration -->
  <rag-quality-monitor test-query-count="10" min-recall="0.3"
                        latency-warn-ms="500" check-interval-min="120"/>

  <!-- v12.0: Debate Quality Tracker configuration -->
  <debate-quality-tracker max-history="100"
                           diversity-weight="0.3" differentiation-weight="0.4"
                           coverage-weight="0.3"/>

  <!-- v12.0: Autonomy Scheduler configuration -->
  <autonomy-scheduler scan-interval-min="120" debate-interval-min="180"
                       optimize-interval-min="60" rss-heal-threshold-mb="350"
                       episode-dedup-threshold="50"
                       worker-check-interval-min="30"
                       security-audit-interval-min="360"
                       yeren-sync-interval-min="60"/>

  <!-- v12.0: Token Tracking configuration -->
  <token-tracking enabled="true" budget-daily="50000"
                   persist-interval-ms="5000" data-file="data/token_usage.json"
                   warn-threshold-pct="80"/>

  <dependencies>
    <dep name="grammy" version="^1" for="rensin"/>
    <dep name="@google/genai" version="^1.44" for="both"/>
    <dep name="better-sqlite3" version="^11" for="both"/>
    <dep name="opossum" version="^9" for="both"/>
    <dep name="pino" version="^9" for="both"/>
    <dep name="fast-xml-parser" version="^4" for="both"/>
  </dependencies>

  <protection>
    <immutable-files>golem-config.xml,.env</immutable-files>
    <self-coder require-approval="true">
      <forbidden-targets>*.service,*.xml,.env,constitution.py</forbidden-targets>
    </self-coder>
  </protection>

</golem-config>
